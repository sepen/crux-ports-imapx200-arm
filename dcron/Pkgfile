# Description: Multi-user cron daemon
# URL: https://www.jimpryor.net/linux/dcron.html
# Maintainer: CRUX System Team, core-ports at crux dot nu

name=dcron
version=4.6
release=1
source=(https://github.com/ptchinster/dcron/archive/v$version/$name-$version.tar.gz
    crontab runjobs crond)

build() {
    cd $name-$version

    # GCC 7 doesn't understand C23's [[fallthrough]] attribute, so replace it
    # with the classic comment form that -Wimplicit-fallthrough still recognizes.
    sed -i 's/\[\[fallthrough\]\];.*$/\/* fall through *\//' main.c

    make PREFIX=/usr
    make DESTDIR=$PKG CRONTAB_GROUP=users install

    install -m 600 $SRC/crontab $PKG/var/spool/cron/crontabs/root
    ln -s ../var/spool/cron/crontabs/root $PKG/etc/crontab
    install -D -m 755 $SRC/crond $PKG/etc/rc.d/crond
    install -D -m 755 $SRC/runjobs $PKG/usr/sbin/runjobs

    install -d $PKG/etc/cron/{hourly,daily,weekly,monthly}
}

