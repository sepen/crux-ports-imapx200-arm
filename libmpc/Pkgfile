# Description: C library for the arithmetic of complex numbers
# URL: https://www.multiprecision.org
# Maintainer: CRUX System Team, core-ports at crux dot nu
# Depends on: libmpfr

name=libmpc
version=1.4.1
release=1
source=(https://ftp.gnu.org/gnu/mpc/mpc-$version.tar.xz)

build() {
    cd mpc-$version

    ./configure --prefix=/usr
    make
    make DESTDIR=$PKG install

    rm -r $PKG/usr/share
}
