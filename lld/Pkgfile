# Description: Linker from the LLVM project
# URL: https://lld.llvm.org/
# Maintainer: CRUX System Team, core-ports at crux dot nu
# Depends on: llvm

name=lld
version=22.1.8
release=1
source=(https://github.com/llvm/llvm-project/releases/download/llvmorg-$version/llvm-project-$version.src.tar.xz
  0002-PATCH-lld-Import-compact_unwind_encoding.h-from-libu.patch)

build() {
  patch -d llvm-project-$version.src/lld -p2 -i $SRC/0002-PATCH-lld-Import-compact_unwind_encoding.h-from-libu.patch

  cmake -S llvm-project-$version.src/lld -B build -G Ninja \
    -D CMAKE_INSTALL_PREFIX=/usr \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_C_FLAGS_RELEASE="$CFLAGS" \
    -D CMAKE_CXX_FLAGS_RELEASE="$CXXFLAGS" \
    -D LLVM_LINK_LLVM_DYLIB=ON \
    -D LLVM_PARALLEL_COMPILE_JOBS=1 \
    -D LLVM_PARALLEL_LINK_JOBS=1 \
    -Wno-dev

  cmake --build build
  DESTDIR=$PKG cmake --install build
}
