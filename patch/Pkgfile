# Description: GNU patch
# URL: http://www.gnu.org/software/patch/patch.html
# Maintainer: CRUX System Team, core-ports at crux dot nu

name=patch
version=2.8
release=1
source=(https://ftpmirror.gnu.org/$name/$name-$version.tar.xz)

build() {
    cd $name-$version

    ./configure \
        --prefix=/usr \
        --disable-year2038

    make
    make DESTDIR=$PKG install
}
