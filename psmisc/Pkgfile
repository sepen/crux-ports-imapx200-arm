# Description: Small utilities that use the /proc filesystem
# URL: https://gitlab.com/psmisc/psmisc
# Maintainer: CRUX System Team, core-ports at crux dot nu
# Depends on: ncurses

name=psmisc
version=23.7
release=1
source=(https://gitlab.com/psmisc/psmisc/-/archive/v$version/$name-$version.tar.bz2
	compat-statx.h)

build() {
    cd $name-v$version-*

    export CFLAGS="$CFLAGS -D_GNU_SOURCE -include $SRC/compat-statx.h"
    export LINGUAS=' '

    ./autogen.sh
    ./configure --prefix=/usr --disable-nls

    make
    make DESTDIR=$PKG install

    rm $PKG/usr/bin/pstree.x11
}
