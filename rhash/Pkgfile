# Description: Great utility for computing hash sums
# URL: https://github.com/rhash/RHash
# Maintainer: CRUX System Team, core-ports at crux dot nu
# Arch Maintainer: CRUX-ARM System Team, devel at crux-arm dot nu

name=rhash
version=1.4.6
release=1
source=(https://github.com/rhash/RHash/archive/v$version/$name-$version.tar.gz)

build() {
    cd RHash-$version

    ./configure  \
      --prefix=/usr \
      --sysconfdir=/etc \
      --enable-lib-{static,shared} \
      --extra-cflags="$CFLAGS" \
      --extra-ldflags="$LDFLAGS"

    make -j1
    # Avoid tests under docker
    # make test test-lib

    make DESTDIR=$PKG -j1 install
    make -C librhash DESTDIR=$PKG -j1 install-lib-headers install-so-link

    install -Dm0644 -o root -g root dist/librhash.pc \
      $PKG/usr/lib/pkgconfig/librhash.pc
}
