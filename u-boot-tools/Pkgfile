# Description: U-Boot tools
# URL: http://www.denx.de/wiki/U-Boot/WebHome
# Maintainer: Jose V Beneyto, sepen at crux-arm dot nu
# Depends on: swig

name=u-boot-tools
version=2026.04
release=1
source=(ftp://ftp.denx.de/pub/u-boot/u-boot-$version.tar.bz2)

build() {
  cd u-boot-$version

  # imapx200 do not use signed EFI capsules
  sed -i 's/mkeficapsule//' tools/Makefile

  make sandbox_config
  make V=1 tools TOOLSUBDIRS=""

  install -d -m 0755 $PKG/usr/{bin,share/man/man1}
  install -m 0755 tools/mk{,env}image $PKG/usr/bin
  install -m 0644 doc/mkimage.1 $PKG/usr/share/man/man1
} 
